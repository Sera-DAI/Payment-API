{
	"info": {
		"_postman_id": "7d9b9a6b-9c8e-4a6c-9407-7d8fa315fbb1",
		"name": "API-Payment",
		"description": "Collection for Payment API endpoints including Pix creation, webhook confirmation, QR code retrieval, and checkout page view.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Pix Payment",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"value\": 150.75\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/payment/pix",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"payment",
						"pix"
					]
				},
				"description": "Creates a new payment transaction with a 30-minute validity, triggers QR Code generation, and returns payment details."
			},
			"response": []
		},
		{
			"name": "Confirm Pix Payment (Webhook)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"bank_payment_id\": \"a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d\",\n    \"value\": 150.75\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/payment/pix/confirmation",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"payment",
						"pix",
						"confirmation"
					]
				},
				"description": "Simulates payment confirmation webhook from external bank. It marks the payment as paid and triggers a Socket.IO event."
			},
			"response": []
		},
		{
			"name": "Get QR Code Image",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/payment/pix/qrcode/:file_name",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"payment",
						"pix",
						"qrcode",
						":file_name"
					],
					"variable": [
						{
							"key": "file_name",
							"value": "qr_code_payment_example",
							"description": "The file name of the saved QR Code image (without .png extension)"
						}
					]
				},
				"description": "Retrieves the dynamically generated QR Code image file for the given payment."
			},
			"response": []
		},
		{
			"name": "Pix Checkout / Confirmation Page",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/payment/pix/:payment_id",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"payment",
						"pix",
						":payment_id"
					],
					"variable": [
						{
							"key": "payment_id",
							"value": "1",
							"description": "ID of the payment transaction in database"
						}
					]
				},
				"description": "Renders the web page displaying the payment state. If paid, displays a confirmation; if unpaid, displays the QR Code for scanning."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:5000",
			"type": "string"
		}
	]
}
